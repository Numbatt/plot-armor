# AniList OAuth public client id. Register an app at
# https://anilist.co/settings/developer and set its redirect URL to the value
# of VITE_ANILIST_REDIRECT_URI below (the hosted callback page).
VITE_ANILIST_CLIENT_ID=

# Hosted OAuth callback page the extension watches for after AniList redirects.
# Must exactly match the redirect URL registered in the AniList app settings.
VITE_ANILIST_REDIRECT_URI=https://plot-armor-sigma.vercel.app/callback.html
